# Auto-detect text files and normalize line endings
* text=auto

# Force LF line endings for code
*.js  text eol=lf
*.jsx text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md  text eol=lf
*.json text eol=lf
*.sh  text eol=lf

# Windows-specific line endings for batch files
*.bat text eol=crlf
